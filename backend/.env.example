# Database
DATABASE_URL=postgresql+asyncpg://scholarsync:scholarsync123@localhost:5432/scholarsync

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Auth
SECRET_KEY=your-secret-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SUMMARY_MODEL=llama3.2:3b
OLLAMA_OVERLAP_MODEL=llama3.1:8b

# SciBERT
SCIBERT_MODEL=allenai/scibert_scivocab_uncased

# Firebase (push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# SendGrid (email)
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@scholarsync.app

# External APIs
SEMANTIC_SCHOLAR_API_KEY=
ARXIV_MAX_RESULTS=50
PUBMED_MAX_RESULTS=50

# Environment
ENVIRONMENT=development
